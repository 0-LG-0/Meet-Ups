<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include('partials/_navbar.ejs') %>
    <h1 id="title">Home</h1>
    
    <p>Share events with potential attendees</p>
    <!-- figure out what to do if user signed in -->
    <% if (user) { %>
        <p style="font-size: 18px;"><strong>User: <%= user.username %></strong> logged in</p>
    <% } %>
    <% if (!user) { %>
    <div class="buttons">
    <a id="sign-up" href="/sign-up">Sign Up</a>
    <a id="sign-in" href="">Sign In</a>
    </div>
    <% } %>
</body>
</html>