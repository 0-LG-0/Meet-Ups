<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body id="home">
    <%- include('partials/_navbar.ejs') %>
    <h1 id="homeTitle">MeetUps</h1>
    
    <h3>Share events with potential attendees</h3>
    <% if (user) { %>
        <p style="font-size: 18px;"><strong>User: <%= user.username %></strong> logged in</p>
    <% } %>
    <% if (!user) { %>
    <div class="homeButtons">
    <a class="authButton" href="/sign-up">Sign Up</a>
    <a class="authButton" href="/sign-in">Sign In</a>
    </div>
    <% } %>
    

</body>
</html>