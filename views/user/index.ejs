<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Events</title>
    <link rel="stylesheet" href="../css/style.css">
</head>
<body id="eventsIndex">
    <%- include('../partials/_navbar.ejs') %>
    <div id="indexTitle">
    <h1 id="inTitle">MeetUps</h1>
    <h2 id="inSub">My Events</h2>
    </div>
    
        <% events.forEach((event) => { %>
        <% if (event.author === User.username) { %>
            <a href="/events/user/<%= event._id %>" style="text-decoration: none; color: black;">
            <div id="eventPreview" style="margin: 10px 20px; border: 2px solid black; padding: 10px;">
            <div id="innerEPreview">
            <h3 id="iEName"><%= event.name %></h3>
            <p id="indexAuthor"><strong>Author: </strong><%= event.author %></p>
            </div>
            <div id="indDescription">
            <p><%= event.description %></p>
            </div>
            </div>
            </a>
            <% } %>
        <% }) %>
</body>
</html>